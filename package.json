{
  "name": "pi-extensions",
  "type": "module",
  "private": true,
  "description": "Custom pi coding-agent extensions: bwrap sandbox, workspace guard, opencode edit, and more",
  "scripts": {
    "check": "tsc --noEmit && prettier --check .",
    "format": "prettier --write .",
    "build:cli": "esbuild bin/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --external:@earendil-works/pi-coding-agent --external:typebox --external:node:*",
    "test": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.6.0",
    "typebox": "1.3.1",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "pi": {
    "extensions": [
      "src/bwrap/index.ts",
      "src/workspace-guard.ts",
      "src/opencode-edit.ts",
      "src/bash-default-timeout.ts",
      "src/agents-md-user-message.ts",
      "src/gh-readonly.ts",
      "src/todo-pendant.ts"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.15.0"
}
